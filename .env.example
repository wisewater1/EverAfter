# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Frontend -> FastAPI app backend
VITE_API_BASE_URL=http://localhost:8010

# Frontend -> health-api provider integration backend
VITE_HEALTH_API_BASE_URL=http://localhost:4000

# Base URL (must be public HTTPS for OAuth)
BASE_URL=https://app.yourdomain.com

# PostgreSQL Database (for Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/everafter

# Session Secret
JWT_SECRET_KEY=replace_me_with_random_string
ALLOW_PRESENTATION_DEMO_AUTH=false
DEMO_AUTH_TOKEN=

# Terra Health Integration
TERRA_API_KEY=your_terra_api_key_here
TERRA_DEV_ID=your_terra_dev_id_here
TERRA_WEBHOOK_SECRET=your_terra_webhook_secret_here

# Mobile Bridges (signed shared secret for Apple Health / Health Connect)
BRIDGE_SHARED_SECRET=replace_me_with_random_string

# OpenAI for Raphael Insights
OPENAI_API_KEY=your_openai_api_key

# Joseph voice / voice sidecar
VOICE_AI_BASE_URL=http://localhost:8020
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Plaid bank connection for Gabriel transaction sync
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional for OAuth institutions on web
PLAID_REDIRECT_URI=
# Optional webhook if you later add Plaid webhooks
PLAID_WEBHOOK_URL=
# Optional explicit encryption key for bank connector secrets.
# Generate with: python - <<'PY'
# from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
# PY
BANK_CONNECTOR_SECRET=
WISEGOLD_ORACLE_API_KEY=your_wisegold_oracle_api_key_here
CHAINLINK_RPC_URL=
CHAINLINK_XAU_USD_FEED=

# SMTP-backed notifications
SMTP_SERVER=
SMTP_USERNAME=
SMTP_PASSWORD=

# Redis for BullMQ Job Scheduling
REDIS_URL=redis://localhost:6379

# Mock Mode (1 = enabled for demos, 0 = disabled)
MOCK_PROVIDERS=0

# Development Options (for sandbox/local testing)
VITE_DEV_MODE=false
VITE_MOCK_TERRA_DATA=false
VITE_ENABLE_NON_CORE_ROUTES=false
VITE_ALLOW_DEV_MOCKS=false
